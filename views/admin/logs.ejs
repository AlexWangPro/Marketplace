<%- include('../partials/head') %>
<section class="admin-top"><div><p class="eyebrow">Admin</p><h1>Admin Logs</h1></div><a class="btn secondary" href="/admin">Dashboard</a></section>
<nav class="admin-nav"><a href="/admin">Dashboard</a><a href="/admin/machines">Machines</a><a href="/admin/requests">Buyer Requests</a><a href="/admin/logs">Logs</a></nav>
<section class="content-card">
<table class="admin-table">
  <thead><tr><th>Date</th><th>Admin</th><th>Action</th><th>Entity</th><th>Details</th></tr></thead>
  <tbody>
    <% logs.forEach(log => { %>
      <tr>
        <td><%= formatDate(log.created_at) %></td>
        <td><%= log.admin_email || 'System' %></td>
        <td><%= log.action %></td>
        <td><%= log.entity_type || '—' %> #<%= log.entity_id || '—' %></td>
        <td><code><%= JSON.stringify(log.details || {}) %></code></td>
      </tr>
    <% }) %>
  </tbody>
</table>
</section>
<%- include('../partials/foot') %>
