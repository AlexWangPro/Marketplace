<%- include('../partials/head') %>
<section class="admin-shell admin-shell-clean">
  <div class="admin-hero-clean compact-admin-hero">
    <div>
      <p class="eyebrow">Admin</p>
      <h1>Dashboard</h1>
      <p>Manage listings, buyer requests, and introductions in one place.</p>
    </div>
    <div class="admin-hero-actions">
      <span class="mail-pill <%= mailConfigured ? 'ok' : 'warn' %>"><%= mailConfigured ? 'Email ready' : 'Email not configured' %></span>
      <form method="post" action="/admin/logout"><button class="btn secondary" type="submit">Logout</button></form>
    </div>
  </div>
  <nav class="admin-nav clean-admin-nav">
    <a href="/admin" class="active">Dashboard</a>
    <a href="/admin/machines">Machines</a>
    <a href="/admin/requests">Buyer Requests</a>
  </nav>

  <section class="admin-card-grid tidy-admin-metrics">
    <a class="admin-metric-card primary-metric" href="/admin/machines?status=pending_review">
      <span><%= (machineCounts.find(r => r.status === 'pending_review') || {}).count || 0 %></span>
      <strong>Pending review</strong>
      <small>Seller submissions waiting for review.</small>
    </a>
    <a class="admin-metric-card" href="/admin/machines?status=available">
      <span><%= (machineCounts.find(r => r.status === 'available') || {}).count || 0 %></span>
      <strong>Available listings</strong>
      <small>Machines currently visible to buyers.</small>
    </a>
    <a class="admin-metric-card" href="/admin/requests?status=new">
      <span><%= (requestCounts.find(r => r.status === 'new') || {}).count || 0 %></span>
      <strong>New requests</strong>
      <small>Buyer requests that need attention.</small>
    </a>
    <a class="admin-metric-card" href="/admin/requests?status=matched">
      <span><%= (requestCounts.find(r => r.status === 'matched') || {}).count || 0 %></span>
      <strong>Matched</strong>
      <small>Introductions already sent.</small>
    </a>
  </section>

  <section class="admin-two-col clean-admin-two-col">
    <div class="content-card clean-admin-card">
      <div class="card-title-row"><h2>Recent machines</h2><a class="text-link" href="/admin/machines">View all</a></div>
      <table class="admin-table clean-table">
        <thead><tr><th>Machine</th><th>Status</th><th>Location</th><th></th></tr></thead>
        <tbody>
          <% recentMachines.forEach(m => { %>
            <tr>
              <td><strong><%= m.title %></strong><br><small><%= formatDate(m.created_at) %></small></td>
              <td><span class="status-badge <%= m.status %>"><%= statusLabel(m.status) %></span></td>
              <td><%= [m.region,m.country,m.city].filter(Boolean).join(' · ') || '—' %></td>
              <td><a class="btn tiny" href="/admin/machines/<%= m.id %>/preview">Preview</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="content-card clean-admin-card">
      <div class="card-title-row"><h2>Recent buyer requests</h2><a class="text-link" href="/admin/requests">View all</a></div>
      <table class="admin-table clean-table">
        <thead><tr><th>Buyer</th><th>Type</th><th>Status</th><th></th></tr></thead>
        <tbody>
          <% recentRequests.forEach(r => { %>
            <tr>
              <td><strong><%= r.buyer_name %></strong><br><small><%= formatDate(r.created_at) %></small></td>
              <td><%= r.request_type === 'contact' ? 'Contact' : 'Buying' %></td>
              <td><span class="status-badge <%= r.status %>"><%= statusLabel(r.status) %></span></td>
              <td><a class="btn tiny" href="/admin/requests/<%= r.id %>">Review</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="content-card clean-admin-card email-status-card simple-email-card">
    <div>
      <strong>Email</strong>
      <span><%= mailConfigured ? 'Configured and ready for buyer / seller introductions.' : 'Add RESEND_API_KEY and MAIL_FROM in Railway Variables to enable emails.' %></span>
    </div>
    <form method="post" action="/admin/email/test" class="email-test-form compact-email-test">
      <input type="email" name="to" placeholder="Send test email to" value="<%= admin && admin.email ? admin.email : '' %>">
      <button class="btn secondary" type="submit">Send test</button>
    </form>
  </section>
</section>
<%- include('../partials/foot') %>
