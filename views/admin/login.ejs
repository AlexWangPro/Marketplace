<%- include('../partials/head') %>
<section class="auth-card auth-card-v37">
  <p class="eyebrow">Admin</p>
  <h1>Sign in</h1>
  <p>Manage seller submissions, buyer requests, machine status, and contact introductions.</p>
  <% if (error) { %><div class="form-errors"><p><%= error %></p></div><% } %>
  <form method="post" action="/admin/login">
    <label>Email<input type="email" name="email" required></label>
    <label>Password<input type="password" name="password" required></label>
    <button class="btn primary large" type="submit">Sign in</button>
  </form>
</section>
<%- include('../partials/foot') %>
