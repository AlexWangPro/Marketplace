<%- include('../partials/head') %>
<section class="auth-card auth-card-v37">
  <p class="eyebrow">Admin</p>
  <h1>Sign in</h1>
  <p>Manage seller submissions, buyer requests, machine status, and contact introductions.</p>
  <% if (error) { %><div class="form-errors"><p><%= error %></p></div><% } %>
  <% const cfg = typeof adminConfig !== 'undefined' ? adminConfig : null; %>
  <% if (cfg) { %>
    <div class="admin-login-hint">
      <strong>Current Railway admin config</strong>
      <span>Email: <%= cfg.emailMasked %></span>
      <span>ADMIN_EMAIL: <%= cfg.emailConfigured ? 'set' : 'default' %> · ADMIN_PASSWORD: <%= cfg.passwordConfigured ? 'set' : 'default' %> · DB sync: <%= cfg.databaseUserSynced ? 'ok' : 'pending' %></span>
    </div>
  <% } %>
  <form method="post" action="/admin/login" autocomplete="on">
    <label>Email<input type="email" name="email" autocomplete="username" required></label>
    <label>Password<input type="password" name="password" autocomplete="current-password" required></label>
    <button class="btn primary large" type="submit">Sign in</button>
  </form>
</section>
<%- include('../partials/foot') %>
