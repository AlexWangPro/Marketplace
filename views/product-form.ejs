<%- include('partials/header') %>
<section class="page-hero compact">
  <span class="eyebrow"><%= mode === 'create' ? 'New submission' : 'Edit submission' %></span>
  <h1><%= mode === 'create' ? 'Publish Product' : 'Edit Product' %></h1>
  <p>Images are stored directly in the database for MVP simplicity. Limit: 5 images, 2MB each.</p>
</section>

<section class="section narrow">
  <form method="post" action="<%= action %>" enctype="multipart/form-data" class="stack-form rich-card">
    <div class="form-grid">
      <label>Product title *<input name="title" value="<%= product.title || '' %>" required></label>
      <label>Category
        <select name="category_id">
          <option value="">Select category</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>" <%= Number(product.category_id) === Number(c.id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </label>
    </div>
    <label>Short summary<textarea name="summary" rows="3"><%= product.summary || '' %></textarea></label>
    <label>Description *<textarea name="description" rows="8" required><%= product.description || '' %></textarea></label>
    <div class="form-grid">
      <label>Price<input type="number" step="0.01" name="price" value="<%= product.price || '' %>" placeholder="Optional"></label>
      <label>Currency<input name="currency" value="<%= product.currency || 'USD' %>"></label>
      <label>Location<input name="location" value="<%= product.location || '' %>" placeholder="City / Country"></label>
      <label>Company<input name="company" value="<%= product.company || '' %>"></label>
    </div>
    <div class="form-grid">
      <label>Contact email<input type="email" name="contact_email" value="<%= product.contact_email || '' %>"></label>
      <label>WhatsApp number<input name="whatsapp" value="<%= product.whatsapp || '' %>" placeholder="Country code + number"></label>
      <label>Website<input type="url" name="website" value="<%= product.website || '' %>" placeholder="https://"></label>
    </div>
    <% if (mode === 'edit' && product.images && product.images.length) { %>
      <div>
        <strong>Current images</strong>
        <div class="thumbs edit-thumbs">
          <% product.images.forEach(img => { %><img src="<%= img.image_data_url %>" alt=""><% }) %>
        </div>
        <p class="muted">Upload new images only if you want to replace all current images.</p>
      </div>
    <% } %>
    <label>Product images<input type="file" name="images" accept="image/png,image/jpeg,image/webp,image/gif" multiple></label>
    <div class="form-actions">
      <button class="button" type="submit"><%= mode === 'create' ? 'Submit for Review' : 'Save Changes' %></button>
      <a class="button ghost" href="/dashboard">Cancel</a>
    </div>
  </form>
</section>
<%- include('partials/footer') %>
