<%- include('../partials/head') %>
<section class="page-hero narrow">
  <p class="eyebrow">Buyer request</p>
  <h1>Tell us what used wall printer you are looking for.</h1>
  <p>Submit your requirements and admin can match you with suitable listings or sellers. We do not verify or guarantee any machine; buyer due diligence is required.</p>
</section>

<% if (errors && errors.length) { %><div class="form-errors"><% errors.forEach(e => { %><p><%= e %></p><% }) %></div><% } %>

<form class="form-shell" method="post" action="/buying-request">
  <section class="form-card">
    <h2>Buyer contact</h2>
    <div class="form-grid two">
      <label>Your name *<input name="buyer_name" value="<%= form.buyer_name || '' %>" required></label>
      <label>Company<input name="buyer_company" value="<%= form.buyer_company || '' %>"></label>
      <label>Email *<input type="email" name="buyer_email" value="<%= form.buyer_email || '' %>" required></label>
      <label>Phone<input name="buyer_phone" value="<%= form.buyer_phone || '' %>"></label>
      <label>WhatsApp<input name="buyer_whatsapp" value="<%= form.buyer_whatsapp || '' %>"></label>
      <label>Your country *<input name="buyer_country" value="<%= form.buyer_country || '' %>" required></label>
    </div>
  </section>

  <section class="form-card">
    <h2>Machine requirement</h2>
    <div class="form-grid two">
      <label>Target region
        <select name="target_region">
          <option value="">Any region</option>
          <% regions.forEach(r => { %><option value="<%= r %>" <%= form.target_region === r ? 'selected' : '' %>><%= r %></option><% }) %>
        </select>
      </label>
      <label>Budget range<input name="budget" value="<%= form.budget || '' %>" placeholder="e.g. USD 10,000 - 25,000"></label>
      <label>Preferred brand<input name="preferred_brand" value="<%= form.preferred_brand || '' %>"></label>
      <label>Preferred printheads<input name="preferred_printheads" value="<%= form.preferred_printheads || '' %>" placeholder="Ricoh GH2220, 4 heads, etc."></label>
      <label>Purchase timeline<input name="timeline" value="<%= form.timeline || '' %>" placeholder="Immediately / 1-3 months / later"></label>
      <label>Need shipping support?<input name="shipping_help" value="<%= form.shipping_help || '' %>" placeholder="Yes / No / Not sure"></label>
    </div>
    <label>Inspection plan<textarea name="inspection_plan" rows="3" placeholder="Will you inspect in person, use a local representative, or request live video demonstration?"><%= form.inspection_plan || '' %></textarea></label>
    <label>Additional requirements<textarea name="message" rows="5"><%= form.message || '' %></textarea></label>
  </section>

  <section class="declaration-box compact">
    <h2>Buyer acknowledgement</h2>
    <p>I understand that Wall Printer Exchange does not inspect, guarantee, sell, warrant, collect payment, ship, install, or provide after-sales service for any listed machine. I am responsible for verifying the machine, seller, ownership, payment terms, shipping, customs, and all transaction details before purchase.</p>
    <label class="check-row"><input type="checkbox" name="verification_ack" <%= form.verification_ack ? 'checked' : '' %>> I understand and accept buyer verification responsibility.</label>
  </section>

  <button class="btn primary large" type="submit">Submit Buying Request</button>
</form>
<%- include('../partials/foot') %>
