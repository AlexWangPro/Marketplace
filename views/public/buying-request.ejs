<%- include('../partials/head') %>
<section class="page-hero narrow apple-page-hero">
  <p class="eyebrow">Buyer Request</p>
  <h1>Tell us what used wall printer you need.</h1>
  <p>Admin can match your request with up to five available or reserved machines.</p>
</section>
<% if (errors && errors.length) { %><div class="form-errors"><% errors.forEach(e => { %><p><%= e %></p><% }) %></div><% } %>
<form class="form-shell" method="post" action="/buying-request">
  <section class="form-card">
    <h2>Buyer contact</h2>
    <div class="form-grid two">
      <label>Your name *<input name="buyer_name" value="<%= form.buyer_name || '' %>" required></label>
      <label>Company<input name="buyer_company" value="<%= form.buyer_company || '' %>"></label>
      <label>Email *<input type="email" name="buyer_email" value="<%= form.buyer_email || '' %>" required></label>
      <label>Phone<input name="buyer_phone" value="<%= form.buyer_phone || '' %>"></label>
      <label>WhatsApp<input name="buyer_whatsapp" value="<%= form.buyer_whatsapp || '' %>"></label>
      <label>Your country *<input name="buyer_country" value="<%= form.buyer_country || '' %>" required></label>
    </div>
  </section>
  <section class="form-card">
    <h2>Machine requirement</h2>
    <div class="form-grid two">
      <label>Target region<select name="target_region"><option value="">Any region</option><% regions.forEach(r => { %><option value="<%= r %>" <%= form.target_region === r ? 'selected' : '' %>><%= r %></option><% }) %></select></label>
      <label>Budget range<input name="budget" value="<%= form.budget || '' %>"></label>
      <label>Preferred brand<input name="preferred_brand" value="<%= form.preferred_brand || '' %>"></label>
      <label>Preferred printheads<input name="preferred_printheads" value="<%= form.preferred_printheads || '' %>"></label>
      <label>Purchase timeline<input name="timeline" value="<%= form.timeline || '' %>"></label>
      <label>Inspection plan<select name="inspection_plan"><option value="">Select option</option><% inspectionPlans.forEach(plan => { %><option value="<%= plan %>" <%= form.inspection_plan === plan ? 'selected' : '' %>><%= plan %></option><% }) %></select></label>
    </div>
    <label>Message<textarea name="message" rows="4"><%= form.message || '' %></textarea></label>
  </section>
  <section class="declaration-box compact">
    <p>I understand that Wall Printer Exchange does not inspect, guarantee, sell, warrant, collect payment, ship, install, or provide after-sales service for any listed machine. I am responsible for verifying the machine, seller, ownership, payment terms, shipping, customs, and all transaction details before purchase.</p>
    <label class="check-row"><input type="checkbox" name="verification_ack" <%= form.verification_ack ? 'checked' : '' %> required> I understand and accept buyer verification responsibility.</label>
  </section>
  <button class="btn primary large" type="submit">Submit buying request</button>
</form>
<%- include('../partials/foot') %>
