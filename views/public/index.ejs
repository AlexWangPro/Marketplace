<%- include('../partials/head') %>
<section class="apple-hero">
  <p class="eyebrow">Wall Printer Exchange</p>
  <h1>Used wall printers, clearly presented.</h1>
  <p>Browse reviewed listings by region and status. Seller contact information is released only after admin approval.</p>
</section>

<section class="apple-filter-panel">
  <form class="filters apple-filters" method="get" action="/">
    <input type="search" name="q" placeholder="Search brand, model, country..." value="<%= filters.q || '' %>">
    <select name="region">
      <option value="">All regions</option>
      <% regions.forEach(r => { %>
        <option value="<%= r %>" <%= filters.region === r ? 'selected' : '' %>><%= r %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="">All statuses</option>
      <option value="available" <%= filters.status === 'available' ? 'selected' : '' %>>Available</option>
      <option value="reserved" <%= filters.status === 'reserved' ? 'selected' : '' %>>Reserved</option>
      <option value="sold" <%= filters.status === 'sold' ? 'selected' : '' %>>Sold</option>
    </select>
    <button class="btn primary" type="submit">Search</button>
  </form>
  <div class="region-pills apple-region-pills">
    <a class="pill <%= !filters.region ? 'active' : '' %>" href="/">All</a>
    <% regions.forEach(r => { const stat = stats.find(s => s.region === r); %>
      <a class="pill <%= filters.region === r ? 'active' : '' %>" href="/?region=<%= encodeURIComponent(r) %>"><%= r %><span><%= stat ? stat.count : 0 %></span></a>
    <% }) %>
  </div>
</section>

<section class="apple-section-head">
  <div>
    <p class="eyebrow">Machines</p>
    <h2>Current listings</h2>
  </div>
  <p><%= machines.length %> listing<%= machines.length === 1 ? '' : 's' %></p>
</section>

<% if (!machines.length) { %>
  <section class="empty-state apple-empty-state">
    <h3>No machines match this filter.</h3>
    <p>Use the floating Buying Request button to tell us what you need.</p>
  </section>
<% } else { %>
  <section class="machine-grid apple-machine-grid">
    <% machines.forEach(machine => { %>
      <article class="machine-card apple-machine-card <%= machine.status === 'sold' ? 'is-sold' : '' %>">
        <a href="/machine/<%= machine.slug %>" class="card-image apple-card-image">
          <% if (machine.primary_image_id) { %>
            <img src="/images/<%= machine.primary_image_id %>" alt="<%= machine.title %>">
          <% } else { %>
            <div class="placeholder-image">Wall Printer</div>
          <% } %>
          <span class="status-badge <%= machine.status %>"><%= statusLabel(machine.status) %></span>
        </a>
        <div class="card-body apple-card-body">
          <p class="meta"><%= [machine.region, machine.country, machine.city].filter(Boolean).join(' · ') || 'Location TBC' %></p>
          <h3><a href="/machine/<%= machine.slug %>"><%= machine.title %></a></h3>
          <p class="specs"><%= [machine.brand, machine.model, machine.printhead_type, machine.printhead_count ? machine.printhead_count + ' heads' : null].filter(Boolean).join(' · ') || 'Specs pending' %></p>
          <div class="apple-card-bottom">
            <p class="price"><%= machine.status === 'sold' ? 'Sold' : money(machine.asking_price, machine.currency) %><% if (machine.price_negotiable && machine.status !== 'sold') { %> <span>Negotiable</span><% } %></p>
            <a class="card-link" href="/machine/<%= machine.slug %>">View</a>
          </div>
        </div>
      </article>
    <% }) %>
  </section>
<% } %>

<section class="apple-micro-note">
  <strong>Buyer-led verification.</strong>
  <span>Wall Printer Exchange does not inspect, guarantee, sell, collect payment, ship, install, or warrant listed machines.</span>
</section>
<%- include('../partials/foot') %>
