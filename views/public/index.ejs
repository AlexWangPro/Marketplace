<%- include('../partials/head') %>
<section class="catalog-hero apple-catalog-hero">
  <div class="catalog-hero-copy apple-hero-copy">
    <p class="eyebrow">Wall Printer Exchange</p>
    <h1>Used wall printers, presented clearly.</h1>
    <p class="hero-text">A focused exchange for used wall printer machines, seller introductions, and buyer-led verification.</p>
  </div>
</section>

<section class="trust-strip-v35" aria-label="Platform approach">
  <article>
    <span>01</span>
    <strong>Reviewed submissions</strong>
    <p>Seller machines are submitted for admin review before they appear publicly.</p>
  </article>
  <article>
    <span>02</span>
    <strong>Private seller details</strong>
    <p>Direct seller contact information is released only through a reviewed introduction flow.</p>
  </article>
  <article>
    <span>03</span>
    <strong>Buyer-led verification</strong>
    <p>Buyers remain responsible for inspection, payment terms, shipping, customs, and final due diligence.</p>
  </article>
</section>

<section class="search-drawer-shell" aria-label="Search machines">
  <div class="search-drawer-head">
    <div>
      <p class="eyebrow">Catalog</p>
      <h2>Available machines</h2>
    </div>
    <button class="search-toggle-btn" type="button" data-search-toggle aria-expanded="<%= (filters.q || filters.region || filters.status) ? 'true' : 'false' %>" aria-controls="machineSearchDrawer">
      <span>Search & filters</span>
      <small><%= [filters.q ? 'Keyword' : null, filters.region || null, filters.status ? statusLabel(filters.status) : null].filter(Boolean).join(' · ') || 'Open' %></small>
    </button>
  </div>

  <div id="machineSearchDrawer" class="search-drawer <%= (filters.q || filters.region || filters.status) ? 'open' : '' %>">
    <form method="get" action="/" class="search-drawer-form">
      <div class="search-input-row">
        <label class="visually-hidden" for="machineSearch">Search machines</label>
        <input id="machineSearch" type="search" name="q" placeholder="Search model, brand, country, printhead..." value="<%= filters.q || '' %>" autocomplete="off">
        <button class="btn primary" type="submit">Search</button>
      </div>
      <div class="search-filter-row">
        <label>Region
          <select name="region">
            <option value="">All regions</option>
            <% regions.forEach(r => { %>
              <option value="<%= r %>" <%= filters.region === r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </label>
        <label>Status
          <select name="status">
            <option value="">All statuses</option>
            <option value="available" <%= filters.status === 'available' ? 'selected' : '' %>>Available</option>
            <option value="reserved" <%= filters.status === 'reserved' ? 'selected' : '' %>>Reserved</option>
            <option value="sold" <%= filters.status === 'sold' ? 'selected' : '' %>>Sold</option>
          </select>
        </label>
        <div class="search-actions">
          <a class="btn secondary" href="/">Reset</a>
          <button class="btn primary" type="submit">Apply</button>
        </div>
      </div>
    </form>
  </div>
</section>

<% if (!machines.length) { %>
  <section class="empty-state clean-empty-state compact-empty-state">
    <h3>No matching machines.</h3>
    <p>Try another search or submit a buying request from the floating button.</p>
  </section>
<% } else { %>
  <section class="v30-machine-grid refined-machine-grid">
    <% machines.forEach(machine => { %>
      <% const locationText = [machine.region, machine.country, machine.city].filter(Boolean).join(' · ') || 'Location TBC'; %>
      <% const headText = [machine.printhead_type, machine.printhead_count ? machine.printhead_count + ' heads' : null].filter(Boolean).join(' · '); %>
      <article class="v30-machine-card refined-machine-card <%= machine.status === 'sold' ? 'is-sold' : '' %>">
        <a href="/machine/<%= machine.slug %>" class="v30-card-image refined-card-image" aria-label="View <%= machine.title %>">
          <% if (machine.primary_image_id) { %>
            <img src="/images/<%= machine.primary_image_id %>" alt="<%= machine.title %>" loading="lazy">
          <% } else { %>
            <div class="placeholder-image">Wall Printer</div>
          <% } %>
          <span class="status-badge <%= machine.status %>"><%= statusLabel(machine.status) %></span>
        </a>
        <div class="v30-card-body refined-card-body">
          <div class="card-kicker">
            <span class="card-location"><%= locationText %></span>
            <% if (machine.production_year) { %><span class="card-year"><%= machine.production_year %></span><% } %>
          </div>
          <h3><a href="/machine/<%= machine.slug %>"><%= machine.title %></a></h3>
          <div class="v30-card-price refined-card-price"><%= machine.status === 'sold' ? 'Sold' : money(machine.asking_price, machine.currency) %></div>
          <div class="refined-spec-list">
            <% if (machine.brand || machine.model) { %><span><%= [machine.brand, machine.model].filter(Boolean).join(' · ') %></span><% } %>
            <% if (headText) { %><span><%= headText %></span><% } %>
            <% if (machine.working_status) { %><span><%= machine.working_status %></span><% } %>
          </div>
          <a class="v30-card-link refined-card-link" href="/machine/<%= machine.slug %>">View details</a>
        </div>
      </article>
    <% }) %>
  </section>
<% } %>
<%- include('../partials/foot') %>
