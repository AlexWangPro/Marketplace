<%- include('../partials/head') %>
<section class="catalog-hero apple-catalog-hero mobile-first-hero">
  <div class="catalog-hero-copy apple-hero-copy">
    <p class="eyebrow">Wall Printer Exchange</p>
    <h1><%= t('home.hero.title') %></h1>
    <p class="hero-text"><%= t('home.hero.text') %></p>
  </div>
</section>

<section class="search-drawer-shell mobile-machine-entry" aria-label="Search machines">
  <div class="search-drawer-head">
    <div>
      <p class="eyebrow"><%= t('home.catalog') %></p>
      <h2><%= t('home.availableMachines') %></h2>
    </div>
    <button class="search-toggle-btn" type="button" data-search-toggle aria-expanded="<%= (filters.q || filters.region || filters.status) ? 'true' : 'false' %>" aria-controls="machineSearchDrawer">
      <span><%= t('home.searchFilters') %></span>
      <small><%= [filters.q ? t('home.keyword') : null, filters.region || null, filters.status ? statusLabel(filters.status) : null].filter(Boolean).join(' · ') || t('home.open') %></small>
    </button>
  </div>

  <div id="machineSearchDrawer" class="search-drawer <%= (filters.q || filters.region || filters.status) ? 'open' : '' %>">
    <form method="get" action="<%= localPath('/') %>" class="search-drawer-form">
      <div class="search-input-row">
        <label class="visually-hidden" for="machineSearch"><%= t('home.search') %></label>
        <input id="machineSearch" type="search" name="q" placeholder="<%= t('home.searchPlaceholder') %>" value="<%= filters.q || '' %>" autocomplete="off">
        <button class="btn primary" type="submit"><%= t('home.search') %></button>
      </div>
      <div class="search-filter-row">
        <label><%= t('home.region') %>
          <select name="region">
            <option value=""><%= t('home.allRegions') %></option>
            <% regions.forEach(r => { %>
              <option value="<%= r %>" <%= filters.region === r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </label>
        <label><%= t('home.status') %>
          <select name="status">
            <option value=""><%= t('home.allStatuses') %></option>
            <option value="available" <%= filters.status === 'available' ? 'selected' : '' %>><%= t('status.available') %></option>
            <option value="reserved" <%= filters.status === 'reserved' ? 'selected' : '' %>><%= t('status.reserved') %></option>
            <option value="sold" <%= filters.status === 'sold' ? 'selected' : '' %>><%= t('status.sold') %></option>
          </select>
        </label>
        <div class="search-actions">
          <a class="btn secondary" href="<%= localPath('/') %>"><%= t('home.reset') %></a>
          <button class="btn primary" type="submit"><%= t('home.apply') %></button>
        </div>
      </div>
    </form>
  </div>
</section>

<% if (!machines.length) { %>
  <section class="launch-state-card compact-empty-state-v37 mobile-empty-state">
    <p class="eyebrow"><%= t('home.noResultsLabel') %></p>
    <h1><%= t('home.noResults') %></h1>
    <p><%= t('home.noResultsText') %></p>
    <div class="hero-actions centered">
      <a class="btn primary" href="<%= localPath('/') %>"><%= t('home.clearFilters') %></a>
      <button class="btn secondary" type="button" data-open-modal="buying-request"><%= t('home.submitBuyingRequest') %></button>
    </div>
  </section>
<% } else { %>
  <section class="v30-machine-grid refined-machine-grid mobile-card-grid">
    <% machines.forEach(machine => { %>
      <% const locationText = [machine.region, machine.country, machine.city].filter(Boolean).join(' · ') || t('home.locationTbc'); %>
      <% const headText = [machine.printhead_type, machine.printhead_count ? machine.printhead_count + ' heads' : null].filter(Boolean).join(' · '); %>
      <article class="v30-machine-card refined-machine-card mobile-machine-card <%= machine.status === 'sold' ? 'is-sold' : '' %>">
        <a href="<%= localPath('/machine/' + machine.slug) %>" class="v30-card-image refined-card-image" aria-label="<%= t('home.viewMachine') %> <%= machine.title %>">
          <% if (machine.primary_image_id) { %>
            <img class="card-photo-bg" src="/images/<%= machine.primary_image_id %>" alt="" aria-hidden="true" loading="lazy">
            <img class="card-photo-main" src="/images/<%= machine.primary_image_id %>" alt="<%= machine.title %>" loading="lazy">
          <% } else { %>
            <div class="placeholder-image"><%= t('home.wallPrinter') %></div>
          <% } %>
          <span class="status-badge <%= machine.status %>"><%= t('status.' + machine.status) %></span>
        </a>
        <div class="v30-card-body refined-card-body">
          <div class="card-kicker">
            <span class="card-location"><%= locationText %></span>
            <% if (machine.production_year) { %><span class="card-year"><%= machine.production_year %></span><% } %>
          </div>
          <h3><a href="<%= localPath('/machine/' + machine.slug) %>"><%= machine.title %></a></h3>
          <div class="v30-card-price refined-card-price"><%= machine.status === 'sold' ? t('status.sold') : money(machine.asking_price, machine.currency) %></div>
          <div class="refined-spec-list">
            <% if (machine.brand || machine.model) { %><span><%= [machine.brand, machine.model].filter(Boolean).join(' · ') %></span><% } %>
            <% if (headText) { %><span><%= headText %></span><% } %>
            <% if (machine.working_status) { %><span><%= machine.working_status %></span><% } %>
          </div>
          <a class="v30-card-link refined-card-link" href="<%= localPath('/machine/' + machine.slug) %>"><%= t('home.viewMachine') %></a>
        </div>
      </article>
    <% }) %>
  </section>
<% } %>

<section class="trust-strip-v35 mobile-trust-after-list" aria-label="<%= t('home.trust.label') %>">
  <article>
    <span>01</span>
    <strong><%= t('home.trust1.title') %></strong>
    <p><%= t('home.trust1.text') %></p>
  </article>
  <article>
    <span>02</span>
    <strong><%= t('home.trust2.title') %></strong>
    <p><%= t('home.trust2.text') %></p>
  </article>
  <article>
    <span>03</span>
    <strong><%= t('home.trust3.title') %></strong>
    <p><%= t('home.trust3.text') %></p>
  </article>
</section>
<%- include('../partials/foot') %>
