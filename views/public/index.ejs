<%- include('../partials/head') %>
<section class="hero catalog-hero">
  <div class="hero-copy catalog-hero-copy">
    <p class="eyebrow">Used Wall Printer Exchange</p>
    <h1>Available used wall printers, reviewed before listing.</h1>
    <p class="hero-text">Browse used wall printer machines by region, status, brand, model, and location. Seller contact details stay private until an interested buyer request is reviewed by Admin.</p>
  </div>
</section>

<section class="filter-section catalog-filter">
  <form class="filters" method="get" action="/">
    <input type="search" name="q" placeholder="Search brand, model, country..." value="<%= filters.q || '' %>">
    <select name="region">
      <option value="">All regions</option>
      <% regions.forEach(r => { %>
        <option value="<%= r %>" <%= filters.region === r ? 'selected' : '' %>><%= r %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="">All statuses</option>
      <option value="available" <%= filters.status === 'available' ? 'selected' : '' %>>Available</option>
      <option value="reserved" <%= filters.status === 'reserved' ? 'selected' : '' %>>Reserved</option>
      <option value="sold" <%= filters.status === 'sold' ? 'selected' : '' %>>Sold</option>
    </select>
    <button class="btn dark" type="submit">Search</button>
  </form>
  <div class="region-pills compact-region-pills">
    <a class="pill <%= !filters.region ? 'active' : '' %>" href="/">All</a>
    <% regions.forEach(r => { const stat = stats.find(s => s.region === r); %>
      <a class="pill <%= filters.region === r ? 'active' : '' %>" href="/?region=<%= encodeURIComponent(r) %>"><%= r %><span><%= stat ? stat.count : 0 %></span></a>
    <% }) %>
  </div>
</section>

<section class="listings-head catalog-listings-head">
  <div>
    <p class="eyebrow">Machine listings</p>
    <h2>Used wall printers for sale</h2>
  </div>
  <p class="muted listing-note">Available, reserved, and sold machines remain visible for market reference.</p>
</section>

<% if (!machines.length) { %>
  <section class="empty-state compact-empty-state">
    <h3>No machines match this filter yet.</h3>
    <p>Use the floating Buying Request button to submit your requirement.</p>
  </section>
<% } else { %>
  <section class="machine-grid catalog-machine-grid">
    <% machines.forEach(machine => { %>
      <article class="machine-card catalog-machine-card <%= machine.status === 'sold' ? 'is-sold' : '' %>">
        <a href="/machine/<%= machine.slug %>" class="card-image">
          <% if (machine.primary_image_id) { %>
            <img src="/images/<%= machine.primary_image_id %>" alt="<%= machine.title %>">
          <% } else { %>
            <div class="placeholder-image">Wall Printer</div>
          <% } %>
          <span class="status-badge <%= machine.status %>"><%= statusLabel(machine.status) %></span>
        </a>
        <div class="card-body">
          <p class="meta"><%= machine.region || 'Region TBC' %> · <%= machine.country || 'Country TBC' %><%= machine.city ? ' · ' + machine.city : '' %></p>
          <h3><a href="/machine/<%= machine.slug %>"><%= machine.title %></a></h3>
          <p class="specs"><%= [machine.brand, machine.model, machine.printhead_type, machine.printhead_count ? machine.printhead_count + ' heads' : null].filter(Boolean).join(' · ') %></p>
          <p class="price"><%= machine.status === 'sold' ? 'Sold' : money(machine.asking_price, machine.currency) %><% if (machine.price_negotiable && machine.status !== 'sold') { %> <span>Negotiable</span><% } %></p>
          <a class="card-link" href="/machine/<%= machine.slug %>"><%= machine.status === 'sold' ? 'View sold listing' : 'View machine' %></a>
        </div>
      </article>
    <% }) %>
  </section>
<% } %>

<section class="notice-band compact-notice-band">
  <h2>Buyer verification is required.</h2>
  <p>Wall Printer Exchange does not inspect, certify, guarantee, sell, collect payment, ship, install, or warrant any listed used wall printer. Buyers must independently verify machine condition, seller identity, ownership, payment terms, shipping, customs, and after-sale responsibilities.</p>
</section>
<%- include('../partials/foot') %>
