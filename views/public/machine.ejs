<%- include('../partials/head') %>
<% const isPreview = typeof previewMode !== 'undefined' && previewMode; %>
<% if (isPreview) { %>
  <section class="admin-preview-bar">
    <div>
      <strong>Admin preview</strong>
      <span>This is how the public listing will appear after approval.</span>
    </div>
    <div class="preview-actions">
      <form method="post" action="/admin/machines/<%= machine.id %>/status"><input type="hidden" name="status" value="available"><button class="btn primary" type="submit">Approve listing</button></form>
      <a class="btn secondary" href="/admin/machines/<%= machine.id %>/edit">Edit</a>
      <a class="btn secondary" href="/admin/machines">Back</a>
    </div>
  </section>
<% } %>

<section class="machine-detail-top">
  <div class="machine-detail-copy">
    <p class="eyebrow"><%= [machine.region, machine.country, machine.city].filter(Boolean).join(' · ') || 'Location TBC' %></p>
    <h1><%= machine.title %></h1>
    <div class="detail-chip-row">
      <span class="status-badge <%= machine.status %>"><%= statusLabel(machine.status) %></span>
      <strong><%= machine.status === 'sold' ? 'Sold' : money(machine.asking_price, machine.currency) %></strong>
      <% if (machine.price_negotiable && machine.status !== 'sold') { %><span>Negotiable</span><% } %>
    </div>
  </div>
  <div class="detail-action-stack">
    <% if (!isPreview && machine.status !== 'sold') { %>
      <a class="btn primary large" href="/machine/<%= machine.slug %>/request-contact">Request Seller Contact</a>
    <% } else if (!isPreview && machine.status === 'sold') { %>
      <button class="btn primary large" type="button" data-open-modal="buying-request">Request similar machine</button>
    <% } %>
  </div>
</section>

<section class="detail-gallery-section">
  <div class="detail-gallery-main">
    <% if (images.length) { %>
      <button class="gallery-item hero-photo" type="button" data-lightbox-src="/images/<%= images[0].id %>" data-lightbox-alt="<%= machine.title %> primary photo">
        <img src="/images/<%= images[0].id %>" alt="<%= machine.title %> primary photo">
      </button>
    <% } else { %>
      <div class="placeholder-image large">No images uploaded</div>
    <% } %>
  </div>
  <% if (images.length > 1) { %>
    <div class="detail-thumb-strip" aria-label="Machine photos">
      <% images.slice(1).forEach((img, idx) => { %>
        <button class="gallery-item thumb-photo" type="button" data-lightbox-src="/images/<%= img.id %>" data-lightbox-alt="<%= machine.title %> photo <%= idx + 2 %>">
          <img src="/images/<%= img.id %>" alt="<%= machine.title %> photo <%= idx + 2 %>">
        </button>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="machine-essentials">
  <div class="essential-card">
    <span>Brand</span>
    <strong><%= machine.brand || 'Not specified' %></strong>
  </div>
  <div class="essential-card">
    <span>Model</span>
    <strong><%= machine.model || 'Not specified' %></strong>
  </div>
  <div class="essential-card">
    <span>Year</span>
    <strong><%= machine.production_year || machine.purchase_year || 'Not specified' %></strong>
  </div>
  <div class="essential-card">
    <span>Printhead</span>
    <strong><%= [machine.printhead_type, machine.printhead_count ? machine.printhead_count + ' heads' : null].filter(Boolean).join(' · ') || 'Not specified' %></strong>
  </div>
  <div class="essential-card">
    <span>Working status</span>
    <strong><%= machine.working_status || 'Not specified' %></strong>
  </div>
  <div class="essential-card">
    <span>Seller contact</span>
    <strong>Released after approval</strong>
  </div>
</section>

<section class="detail-accordion-stack">
  <details open>
    <summary>Machine notes</summary>
    <div class="detail-prose"><p><%= machine.details || 'No additional description has been published yet.' %></p></div>
  </details>
  <% if (machine.accessories) { %>
    <details>
      <summary>Included accessories</summary>
      <div class="detail-prose"><p><%= machine.accessories %></p></div>
    </details>
  <% } %>
  <% if (machine.known_defects) { %>
    <details>
      <summary>Known defects</summary>
      <div class="detail-prose"><p><%= machine.known_defects %></p></div>
    </details>
  <% } %>
  <% if (machine.video_url) { %>
    <details>
      <summary>Seller video</summary>
      <div class="detail-prose"><p><a class="text-link" href="<%= machine.video_url %>" target="_blank" rel="noopener">Open seller video →</a></p></div>
    </details>
  <% } %>
  <details>
    <summary>Buyer verification reminder</summary>
    <div class="detail-prose"><p>Wall Printer Exchange is a listing and introduction platform only. Buyers verify condition, ownership, payment terms, and logistics directly with the seller before purchase.</p></div>
  </details>
</section>
<%- include('../partials/foot') %>
