<%- include('../partials/head') %>
<% const isPreview = typeof previewMode !== 'undefined' && previewMode; %>
<% if (isPreview) { %>
  <section class="admin-preview-bar">
    <div>
      <strong>Admin preview</strong>
      <span>This is exactly how the public listing content will appear after approval.</span>
    </div>
    <div class="preview-actions">
      <form method="post" action="/admin/machines/<%= machine.id %>/status"><input type="hidden" name="status" value="available"><button class="btn primary" type="submit">Approve listing</button></form>
      <a class="btn secondary" href="/admin/machines/<%= machine.id %>/edit">Edit</a>
      <a class="btn secondary" href="/admin/machines">Back</a>
    </div>
  </section>
<% } %>

<section class="detail-hero apple-detail-hero">
  <div>
    <p class="eyebrow"><%= machine.region || 'Region TBC' %> · <%= machine.country || 'Country TBC' %><%= machine.city ? ' · ' + machine.city : '' %></p>
    <h1><%= machine.title %></h1>
    <div class="detail-meta">
      <span class="status-badge <%= machine.status %>"><%= statusLabel(machine.status) %></span>
      <span><%= machine.status === 'sold' ? 'Sold listing remains visible for reference.' : money(machine.asking_price, machine.currency) %></span>
      <% if (machine.price_negotiable && machine.status !== 'sold') { %><span>Negotiable</span><% } %>
    </div>
  </div>
  <div class="detail-actions">
    <% if (!isPreview && machine.status !== 'sold') { %>
      <a class="btn primary" href="/machine/<%= machine.slug %>/request-contact">Request Seller Contact</a>
    <% } else if (!isPreview && machine.status === 'sold') { %>
      <span class="muted detail-action-note">Sold listing. Use Buying Request for a similar machine.</span>
    <% } %>
  </div>
</section>

<section class="detail-layout apple-detail-layout">
  <div>
    <div class="gallery apple-gallery">
      <% if (images.length) { %>
        <% images.forEach((img, idx) => { %>
          <button class="gallery-item <%= idx === 0 ? 'main-photo' : '' %>" type="button" data-lightbox-src="/images/<%= img.id %>" data-lightbox-alt="<%= machine.title %> photo <%= idx + 1 %>">
            <img src="/images/<%= img.id %>" alt="<%= machine.title %> photo <%= idx + 1 %>">
          </button>
        <% }) %>
      <% } else { %>
        <div class="placeholder-image large">No images uploaded</div>
      <% } %>
    </div>

    <section class="content-card apple-content-card">
      <h2>Description</h2>
      <p><%= machine.details || 'No additional description has been published yet.' %></p>
      <% if (machine.video_url) { %>
        <p><a class="text-link" href="<%= machine.video_url %>" target="_blank" rel="noopener">Open seller video →</a></p>
      <% } %>
    </section>

    <% if (machine.accessories || machine.known_defects) { %>
      <section class="content-card apple-content-card two-note-grid">
        <% if (machine.accessories) { %>
          <div><h2>Included accessories</h2><p><%= machine.accessories %></p></div>
        <% } %>
        <% if (machine.known_defects) { %>
          <div><h2>Known defects</h2><p><%= machine.known_defects %></p></div>
        <% } %>
      </section>
    <% } %>
  </div>

  <aside class="sidebar-card apple-sidebar-card">
    <h2>Specs</h2>
    <dl class="spec-list">
      <dt>Brand</dt><dd><%= machine.brand || 'Not specified' %></dd>
      <dt>Model</dt><dd><%= machine.model || 'Not specified' %></dd>
      <dt>Production year</dt><dd><%= machine.production_year || 'Not specified' %></dd>
      <dt>Purchase year</dt><dd><%= machine.purchase_year || 'Not specified' %></dd>
      <dt>Printhead</dt><dd><%= machine.printhead_type || 'Not specified' %></dd>
      <dt>Head count</dt><dd><%= machine.printhead_count || 'Not specified' %></dd>
      <dt>Working status</dt><dd><%= machine.working_status || 'Not specified' %></dd>
      <dt>Location</dt><dd><%= [machine.region, machine.country, machine.city].filter(Boolean).join(' · ') || 'Not specified' %></dd>
      <dt>Seller contact</dt><dd>Hidden until admin-approved introduction.</dd>
    </dl>
    <p class="sidebar-note">Buyers verify machine condition, ownership, payment terms, and logistics directly with the seller.</p>
  </aside>
</section>
<%- include('../partials/foot') %>
