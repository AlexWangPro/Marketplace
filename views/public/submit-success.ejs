<%- include('../partials/head') %>
<section class="launch-state-card success-state-v37 mobile-page-hero">
  <p class="eyebrow"><%= t('success.received') %></p>
  <% if (type === 'machine') { %><h1><%= t('success.machine.h1') %></h1><p><%= t('success.machine.text') %></p>
  <% } else if (type === 'contact') { %><h1><%= t('success.contact.h1') %></h1><p><%= t('success.contact.text') %></p>
  <% } else { %><h1><%= t('success.buying.h1') %></h1><p><%= t('success.buying.text') %></p><% } %>
  <div class="next-steps-v37"><article><strong>1</strong><span><%= t('success.step1') %></span></article><article><strong>2</strong><span><%= t('success.step2') %></span></article><article><strong>3</strong><span><%= t('success.step3') %></span></article></div>
  <div class="hero-actions centered"><a class="btn primary" href="<%= localPath('/') %>"><%= t('success.back') %></a><a class="btn secondary" href="<%= localPath('/verification-checklist') %>"><%= t('footer.verification') %></a></div>
</section>
<%- include('../partials/foot') %>
