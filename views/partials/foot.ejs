</main>
<%
  const safeFooterT = typeof t !== 'undefined' ? t : (key) => key;
  const safeFooterLocalPath = typeof localPath !== 'undefined' ? localPath : (pathname) => pathname || '/';
  const safeFooterCurrentPath = typeof currentPath !== 'undefined' ? currentPath : '/';
  const safeFooterAdmin = typeof admin !== 'undefined' ? admin : null;
  const safeCanIncludeFloating = typeof t !== 'undefined' && typeof regions !== 'undefined' && typeof inspectionPlans !== 'undefined' && typeof sellerContactMethods !== 'undefined' && typeof workingStatusOptions !== 'undefined' && typeof currencyOptions !== 'undefined';
%>
<footer class="site-footer clean-footer apple-footer site-footer-v37 mobile-clean-footer">
  <div>
    <strong>Wall Printer Exchange</strong>
    <p><%= safeFooterT('footer.text') %></p>
  </div>
  <div class="footer-links footer-quiet-links">
    <a href="<%= safeFooterLocalPath('/about') %>"><%= safeFooterT('nav.about') %></a>
    <a href="<%= safeFooterLocalPath('/buyer-guide') %>"><%= safeFooterT('nav.buyerGuide') %></a>
    <a href="<%= safeFooterLocalPath('/seller-guide') %>"><%= safeFooterT('nav.sellerGuide') %></a>
    <a href="<%= safeFooterLocalPath('/verification-checklist') %>"><%= safeFooterT('footer.verification') %></a>
    <% if (!safeFooterAdmin) { %><a href="/admin/login"><%= safeFooterT('footer.adminLogin') %></a><% } %>
  </div>
</footer>
<% if (!safeFooterCurrentPath.startsWith('/admin') && safeCanIncludeFloating) { %>
  <%- include('../public/floating-modals') %>
<% } %>
<script src="/app.js?v=3.8.7" defer></script>
</body>
</html>
