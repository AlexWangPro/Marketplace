<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title ? title + ' · ' : '' %>Wall Printer Exchange</title>
  <meta name="description" content="Reviewed used wall printer listings, seller introductions, and buyer-led machine verification.">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<header class="site-header minimal-header">
  <a class="brand" href="/">
    <span class="brand-mark">WPE</span>
    <span>
      <strong>Wall Printer Exchange</strong>
      <small>Used wall printer listings</small>
    </span>
  </a>
  <% if (admin) { %>
    <div class="admin-mini-nav">
      <a class="admin-link" href="/admin">Admin</a>
      <form method="post" action="/admin/logout"><button class="btn tiny secondary" type="submit">Logout</button></form>
    </div>
  <% } %>
</header>
<% if (flash) { %>
  <div class="flash <%= flash.type %>"><%= flash.message %></div>
<% } %>
<main>
