<!doctype html>
<html lang="<%= lang || 'en' %>" dir="<%= currentLanguage && currentLanguage.dir ? currentLanguage.dir : 'ltr' %>">
<head>
  <% const pageTitle = title ? title + ' · Wall Printer Exchange' : 'Wall Printer Exchange · Used Wall Printer Listings'; %>
  <% const pageDescription = typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Browse reviewed used wall printer machines, request private seller introductions, and use buyer-led verification before purchase.'; %>
  <% const pageUrl = typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : localizedAbsolute(currentPath || '/'); %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="robots" content="<%= currentPath && currentPath.startsWith('/admin') ? 'noindex,nofollow' : 'index,follow' %>">
  <meta name="theme-color" content="#111827">
  <link rel="canonical" href="<%= pageUrl %>">
  <% if (!currentPath.startsWith('/admin')) { %>
    <% languages.forEach(language => { %>
      <link rel="alternate" hreflang="<%= language.code %>" href="<%= absoluteUrl(langUrl(language.code, currentPath || '/')) %>">
    <% }) %>
    <link rel="alternate" hreflang="x-default" href="<%= absoluteUrl(langUrl('en', currentPath || '/')) %>">
  <% } %>
  <meta property="og:site_name" content="Wall Printer Exchange">
  <meta property="og:locale" content="<%= lang === 'en' ? 'en_US' : lang %>">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:url" content="<%= pageUrl %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %><meta property="og:image" content="<%= ogImage %>"><% } %>
  <meta name="twitter:card" content="<%= typeof ogImage !== 'undefined' && ogImage ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <link rel="stylesheet" href="/styles.css?v=3.8">
</head>
<body class="<%= currentLanguage && currentLanguage.dir === 'rtl' ? 'rtl' : '' %>">
<header class="site-header minimal-header mobile-clean-header">
  <a class="brand" href="<%= localPath('/') %>">
    <span class="brand-mark">WPE</span>
    <span>
      <strong>Wall Printer Exchange</strong>
      <small><%= t('brand.subtitle') %></small>
    </span>
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    <a href="<%= localPath('/') %>" class="<%= currentPath === '/' ? 'active' : '' %>"><%= t('nav.machines') %></a>
    <a href="<%= localPath('/buyer-guide') %>" class="<%= currentPath === '/buyer-guide' ? 'active' : '' %>"><%= t('nav.buyerGuide') %></a>
    <a href="<%= localPath('/seller-guide') %>" class="<%= currentPath === '/seller-guide' ? 'active' : '' %>"><%= t('nav.sellerGuide') %></a>
    <a href="<%= localPath('/about') %>" class="<%= currentPath === '/about' ? 'active' : '' %>"><%= t('nav.about') %></a>
  </nav>
  <div class="language-switcher" aria-label="<%= t('nav.language') %>">
    <select class="language-select" data-language-select>
      <% languages.forEach(language => { %>
        <option value="<%= langUrl(language.code, currentPath || '/') %>" <%= language.code === lang ? 'selected' : '' %>><%= language.nativeName %></option>
      <% }) %>
    </select>
  </div>
  <% if (admin) { %>
    <div class="admin-mini-nav">
      <a class="admin-link" href="/admin"><%= t('nav.adminDashboard') %></a>
      <form method="post" action="/admin/logout"><button class="btn tiny secondary" type="submit">Logout</button></form>
    </div>
  <% } %>
</header>
<% if (flash) { %>
  <div class="flash <%= flash.type %>"><%= flash.message %></div>
<% } %>
<main>
