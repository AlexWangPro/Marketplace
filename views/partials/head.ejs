<!doctype html>
<html lang="en">
<head>
  <% const pageTitle = title ? title + ' · Wall Printer Exchange' : 'Wall Printer Exchange · Used Wall Printer Listings'; %>
  <% const pageDescription = typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Browse reviewed used wall printer machines, request private seller introductions, and use buyer-led verification before purchase.'; %>
  <% const pageUrl = typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : absoluteUrl(currentPath || '/'); %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>">
  <meta name="robots" content="<%= currentPath && currentPath.startsWith('/admin') ? 'noindex,nofollow' : 'index,follow' %>">
  <meta name="theme-color" content="#111827">
  <link rel="canonical" href="<%= pageUrl %>">
  <meta property="og:site_name" content="Wall Printer Exchange">
  <meta property="og:locale" content="en_US">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDescription %>">
  <meta property="og:url" content="<%= pageUrl %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %><meta property="og:image" content="<%= ogImage %>"><% } %>
  <meta name="twitter:card" content="<%= typeof ogImage !== 'undefined' && ogImage ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDescription %>">
  <link rel="stylesheet" href="/styles.css?v=3.7">
</head>
<body>
<header class="site-header minimal-header">
  <a class="brand" href="/">
    <span class="brand-mark">WPE</span>
    <span>
      <strong>Wall Printer Exchange</strong>
      <small>Used wall printer exchange</small>
    </span>
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Machines</a>
    <a href="/buyer-guide" class="<%= currentPath === '/buyer-guide' ? 'active' : '' %>">Buyer Guide</a>
    <a href="/seller-guide" class="<%= currentPath === '/seller-guide' ? 'active' : '' %>">Seller Guide</a>
    <a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a>
  </nav>
  <% if (admin) { %>
    <div class="admin-mini-nav">
      <a class="admin-link" href="/admin">Admin Dashboard</a>
      <form method="post" action="/admin/logout"><button class="btn tiny secondary" type="submit">Logout</button></form>
    </div>
  <% } %>
</header>
<% if (flash) { %>
  <div class="flash <%= flash.type %>"><%= flash.message %></div>
<% } %>
<main>
